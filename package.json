{
  "name": "timesheet-ai",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "next-themes": "^0.4.6",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "dev:worker": "bun run --filter worker dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "db:migrate": "bun run --filter db migrate"
  },
  "dependencies": {
    "@timesheet-ai/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@timesheet-ai/config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "ultracite": "7.6.2"
  },
  "packageManager": "bun@1.3.13"
}
